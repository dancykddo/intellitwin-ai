rom 'lucide-react';\nimport { useState } from 'react';\n\nexport default function UploadPage() {\n  const [dragActive, setDragActive] = useState(false);\n  const [uploadedFiles, setUploadedFiles] = useState<{name: string, type: string, size: string}[]>([\n    { name: 'OS_Chapter_4_Notes.pdf', type: 'pdf', size: '2.4 MB' },\n    { name: 'Database_Schema.png', type: 'image', size: '840 KB' }\n  ]);\n\n  const handleDrag = (e: React.DragEvent) => {\n    e.preventDefault();\n    e.stopPropagation();\n    if (e.type === \"dragenter\" || e.type === \"dragover\") {\n      setDragActive(true);\n    } else if (e.type === \"dragleave\") {\n      setDragActive(false);\n    }\n  };\n\n  const handleDrop = (e: React.DragEvent) => {\n    e.preventDefault();\n    e.stopPropagation();\n    setDragActive(false);\n    if (e.dataTransfer.files && e.dataTransfer.files[0]) {\n      const newFile = e.dataTransfer.files[0];\n      setUploadedFiles([...uploadedFiles, {\n        name: newFile.name,\n        type: newFile.type.includes('image') ? 'image' : 'pdf',\n        size: (newFile.size / 1024 / 1024).toFixed(2) + ' MB'\n      }]);\n    }\n  };\n\n  return (\n    <div className=\"container mx-auto px-4 py-8 max-w-5xl\">\n      <div className=\"mb-8\">\n        <h1 className=\"text-3xl font-outfit font-bold\">Upload Knowledge Base</h1>\n        <p className=\"text-gray-400 mt-2\">Feed your Digital Twin with PDFs, notes, and study schedules.</p>\n      </div>\n\n      <div className=\"grid md:grid-cols-2 gap-8\">\n        {/* Upload Area */}\n        <div \n          className={`glass-panel border-2 border-dashed rounded-3xl p-12 flex flex-col items-center justify-center text-center transition-all ${dragActive ? 'border-[#00f2fe] bg-[#00f2fe]/5' : 'border-white/20'}`}\n          onDragEnter={handleDrag}\n          onDragLeave={handleDrag}\n          onDragOver={handleDrag}\n          onDrop={handleDrop}\n        >\n          <div className=\"w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mb-6\">\n            <UploadCloud className=\"w-10 h-10 text-[#00f2fe]\" />\n          </div>\n          <h3 className=\"text-xl font-bold mb-2\">Drag & Drop files here</h3>\n          <p className=\"text-gray-400 text-sm mb-6 max-w-[250px]\">\n            Supports PDF, DOCX, TXT, PNG, and JPG (Max 50MB per file)\n          </p>\n          <button className=\"px-6 py-3 rounded-full bg-white/10 hover:bg-white/20 transition-colors font-medium text-sm flex items-center gap-2\">\n            <File className=\"w-4 h-4\" />\n            Browse Files Instead\n          </button>\n        </div>\n\n        {/* Uploaded Files List */}\n        <div className=\"space-y-4\">\n          <h3 className=\"text-xl font-bold mb-4\">Recent Uploads</h3>\n          {uploadedFiles.map((file, idx) => (\n            <div key={idx} className=\"glass-card p-4 flex items-center justify-between group\">\n              <div className=\"flex items-center gap-4\">\n                <div className={`p-3 rounded-xl ${file.type === 'pdf' ? 'bg-red-500/10 text-red-500' : 'bg-emerald-500/10 text-emerald-500'}`}>\n                  {file.type === 'pdf' ? <FileText className=\"w-6 h-6\" /> : <ImageIcon className=\"w-6 h-6\" />}\n                </div>\n                <div>\n                  <h4 className=\"font-bold text-sm truncate max-w-[200px]\">{file.name}</h4>\n                  <div className=\"flex items-center gap-2 mt-1\">\n                    <span className=\"text-xs text-gray-500\">{file.size}</span>\n                    <span className=\"w-1 h-1 bg-gray-600 rounded-full\"></span>\n                    <span className=\"text-xs px-2 py-0.5 rounded-md bg-white/5 text-gray-300 capitalize\">{file.type}</span>\n                  </div>\n                </div>\n              </div>\n              <div className=\"flex items-center gap-2\">\n                <button className=\"p-2 text-emerald-400 hover:bg-emerald-400/10 rounded-lg transition-colors\" title=\"AI Processing Complete\">\n                  <CheckCircle2 className=\"w-5 h-5\" />\n                </button>\n                <button className=\"p-2 text-gray-500 hover:text-red-400 hover:bg-red-400/10 rounded-lg transition-colors opacity-0 group-hover:opacity-100\">\n                  <X className=\"w-5 h-5\" />\n                </button>\n              </div>\n            </div>\n          ))}\n          \n          <div className=\"mt-8 p-4 rounded-xl bg-gradient-to-r from-[#00f2fe]/10 to-[#4facfe]/10 border border-[#00f2fe]/20 flex items-start gap-4\">\n            <Brain className=\"w-6 h-6 text-[#00f2fe] shrink-0 mt-1\" />\n            <div>\n              <h4 className=\"font-bold text-sm text-[#00f2fe]\">Auto-Categorization Active</h4>\n              <p className=\"text-xs text-gray-400 mt-1\">Your Digital Twin is currently extracting topics and generating mock questions from the OS Chapter 4 Notes.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\2005s\\Downloads\\Digital Twin AI\\intellitwin-app\\src\\app\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\2005s\\Downloads\\Digital Twin AI\\intellitwin-app\\src\\app\\login\\page.tsx","messages":[{"ruleId":"react/no-unescaped-entities","severity":2,"message":"`'` can be escaped with `&apos;`, `&lsquo;`, `&#39;`, `&rsquo;`.","line":83,"column":14,"nodeType":"JSXText","messageId":"unescapedEntityAlts","suggestions":[{"messageId":"replaceWithAlt","data":{"alt":"&apos;"},"fix":{"range":[3661,3694],"text":"\n          Don&apos;t have an account?"},"desc":"Replace with `&apos;`."},{"messageId":"replaceWithAlt","data":{"alt":"&lsquo;"},"fix":{"range":[3661,3694],"text":"\n          Don&lsquo;t have an account?"},"desc":"Replace with `&lsquo;`."},{"messageId":"replaceWithAlt","data":{"alt"